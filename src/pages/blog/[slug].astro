---
import Layout from '../../layouts/Layout.astro';
import { getSortedPosts, getPostBySlug } from '../../data/blog';

export function getStaticPaths() {
  return getSortedPosts().map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
---

<Layout title={post.title} description={post.excerpt}>
  <article class="post-page">
    <header class="post-header">
      <a href="/blog" class="back-link">← Artículos</a>
      <div class="post-hero-image-wrap">
        <img
          src={post.image}
          alt={post.imageAlt}
          width="800"
          height="400"
          class="post-hero-image"
        />
      </div>
      <div class="post-meta-wrap">
        <time class="post-date" datetime={post.date}>
          {new Date(post.date).toLocaleDateString('es-CO', { day: 'numeric', month: 'long', year: 'numeric' })}
        </time>
        <h1 class="post-title">{post.title}</h1>
      </div>
    </header>
    <div class="post-body set-prose" set:html={post.body} />
  </article>
</Layout>

<style>
  .post-page { padding: 0 0 3rem; max-width: 720px; margin: 0 auto; }
  .back-link {
    display: inline-block;
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--accent-light);
    text-decoration: none;
    margin-bottom: 1rem;
  }
  .back-link:hover { text-decoration: underline; }
  .post-hero-image-wrap {
    border-radius: var(--radius-lg);
    overflow: hidden;
    margin-bottom: 1.5rem;
    box-shadow: var(--shadow);
    aspect-ratio: 2 / 1;
    background: var(--bg);
  }
  .post-hero-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: saturate(0.75) contrast(1.02);
  }
  .post-meta-wrap { margin-bottom: 1.5rem; }
  .post-date {
    display: block;
    font-size: 0.875rem;
    color: var(--accent-light);
    font-weight: 500;
    margin-bottom: 0.5rem;
  }
  .post-title {
    font-size: clamp(1.5rem, 3vw, 1.875rem);
    font-weight: 700;
    color: var(--primary);
    margin: 0;
    line-height: 1.3;
    letter-spacing: -0.02em;
  }
  .post-body {
    font-size: 1rem;
    line-height: 1.7;
    color: var(--text);
  }
  .set-prose :global(p) { margin: 0 0 1rem; }
  .set-prose :global(h3) {
    font-size: 1.125rem;
    font-weight: 600;
    color: var(--primary);
    margin: 1.5rem 0 0.75rem;
  }
  .set-prose :global(ul) {
    margin: 0 0 1rem 1.5rem;
    padding: 0;
  }
  .set-prose :global(li) { margin-bottom: 0.35rem; }
  .set-prose :global(strong) { color: var(--text); }
</style>
