					<SchemaData schemaUrl="#rutas_asorper">
						<SimpleData name="fid">2</SimpleData>
						<SimpleData name="Recorrido">Glorieta MAKRO, hasta la gloerita de postobon, Entra al barrio santa isabel por la transversal 7, carrera 7, barrios santa clara y san nicolas y sigue por la avenida simon bolivar, y gira en el barrio la capilla calle 64, altos de la capilla, camilo torres, y se devuelve a incorporarse a la avenida simon bolivar, hasta barrio san nicolas y santa clara para incorporarse a la avenida ferrocarril, hasta el barrio bosques de la acuarela.</SimpleData>
						<SimpleData name="Comuna">1, 4, 9, 10, 11, 12</SimpleData>
						<SimpleData name="Barrio">SANTA MONICA, VALHER, VILLA FANNY, LA AURORA, SANTA ISABLE, LA CAPILLA, ALTOS DE LA CAPILLA, BOSQUES DE LA ACUARELA</SimpleData>
						<SimpleData name="Frecuencia">Martes - Viernes</SimpleData>
						<SimpleData name="Hora">6:00 am - 12:00 pm</SimpleData>
					</SchemaData>
				</ExtendedData>
