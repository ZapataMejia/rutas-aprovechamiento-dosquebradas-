				<ExtendedData>
					<SchemaData schemaUrl="#rutas_asorper">
						<SimpleData name="fid">1</SimpleData>
						<SimpleData name="Recorrido">Barrios Campestre C por calle 18,pasa a campestre B por la carrera 2 hasta transversal 8,y pasa a campestre A  hasta los puentes industriales pasa por la diagonal 25 por kosta azul, y sigue derecho por diagonal 25F por C.C UNICO, y gira en la carrera 19 por el barrio la pradera, sube por la avenida la pradera y gira en la transversal 21,</SimpleData>
						<SimpleData name="Comuna">1, 3, 4, 5, 7, 12</SimpleData>
						<SimpleData name="Barrio">Campestre A,B,C,D, BOSQUES DE SAN MARTIN, LA PRADERA, QUINTAS DE ARAGON, LA PRIMAVERA, EL RECREO, SAN FELIX, PRIMAVERA AZUL,  QUINTAS JARDIN COLONIAL, MOLIVENTO, MIRADOR DE VILLAVENTO.</SimpleData>
						<SimpleData name="Frecuencia">Lunes - Jueves</SimpleData>
						<SimpleData name="Hora">5:00 am - 12:00 pm</SimpleData>
					</SchemaData>
